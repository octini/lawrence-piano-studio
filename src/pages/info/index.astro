---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Image from '~/components/common/Image.astro';

import pianoKeys from '~/assets/images/studio_photos/piano_keys.jpg';

const metadata = {
  title: 'Information | Lawrence Piano Studio',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText
    title="Information"
  />

  <!-- Piano keys banner image -->
  <div class="max-w-7xl mx-auto px-4 md:px-6 pb-8">
    <Image
      src={pianoKeys}
      alt="Piano keys close-up"
      class="w-full h-48 md:h-64 object-cover rounded-2xl shadow-lg"
      width={1200}
      height={400}
      widths={[600, 900, 1200]}
      sizes="(max-width: 768px) 100vw, 1200px"
    />
  </div>

  <!-- Two large hub cards -->
  <section class="relative not-prose">
    <div class="max-w-5xl mx-auto px-4 md:px-6 pb-16 md:pb-20">
      <div class="grid gap-6 sm:grid-cols-2">

        <!-- FAQ Card -->
        <a
          href="/info/faq"
          class="group flex flex-col items-start gap-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 p-8 shadow-md hover:shadow-xl hover:border-primary dark:hover:border-blue-500 transition-all duration-300"
        >
          <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-heading dark:text-white mb-2 group-hover:text-primary dark:group-hover:text-blue-400 transition-colors">
              Frequently Asked Questions
            </h2>
            <p class="text-muted dark:text-slate-400 text-base leading-relaxed">
                Get answers to many common questions about the Lawrence Piano Studio.
              </p>
          </div>
          <span class="mt-auto inline-flex items-center gap-1 font-semibold text-primary dark:text-blue-400 text-sm group-hover:gap-2 transition-all">
            Read FAQ
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </span>
        </a>

        <!-- Policies Card -->
        <a
          href="/info/policies"
          class="group flex flex-col items-start gap-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 p-8 shadow-md hover:shadow-xl hover:border-primary dark:hover:border-blue-500 transition-all duration-300"
        >
          <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-heading dark:text-white mb-2 group-hover:text-primary dark:group-hover:text-blue-400 transition-colors">
              Studio Policies
            </h2>
            <p class="text-muted dark:text-slate-400 text-base leading-relaxed">
                Our policies on missed lessons, lesson rescheduling, lesson pricing and library feed, and more.
              </p>
          </div>
          <span class="mt-auto inline-flex items-center gap-1 font-semibold text-primary dark:text-blue-400 text-sm group-hover:gap-2 transition-all">
            Read Policies
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </span>
        </a>

      </div>
    </div>
  </section>
</Layout>
