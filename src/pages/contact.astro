---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import nowEnrollingSign from '~/assets/images/studio_photos/now_enrolling_sign.png';

const metadata = {
  title: 'Contact | Lawrence Piano Studio',
};
---

<Layout metadata={metadata}>
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <!-- Page Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold font-heading text-[#1a2e5a] dark:text-white mb-3">
        Get in Touch
      </h1>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        Have questions? Ready to sign up for lessons? Send us an email, give us a call, or use the form below to send us a message!
      </p>
    </div>

<!-- Split-screen grid -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

<!-- LEFT: Contact Information + Image -->
<div class="flex flex-col gap-8">
  <!-- Now Enrolling Image -->
  <div class="rounded-2xl overflow-hidden shadow-lg border border-[#1a2e5a]/20">
    <Image
      src={nowEnrollingSign}
      alt="Now Enrolling — Lawrence Piano Studio"
      class="w-full h-auto object-cover"
      widths={[400, 800]}
      sizes="(max-width: 768px) 100vw, 50vw"
    />
  </div>

  <!-- Contact Info -->
  <div class="bg-blue-50 dark:bg-[#1a2e5a] text-slate-800 dark:text-white rounded-2xl p-8 shadow-lg space-y-6">
    <h2 class="text-2xl font-bold font-heading">Contact Information</h2>

    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 mt-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary dark:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </div>
      <div>
        <p class="font-semibold text-slate-800 dark:text-white/90 mb-1">Phone</p>
        <a href="tel:+17858422182" class="text-primary dark:text-primary hover:text-primary-dark dark:hover:text-white transition-colors">
          (785) 842-2182
        </a>
      </div>
    </div>

    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 mt-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary dark:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div>
        <p class="font-semibold text-slate-800 dark:text-white/90 mb-1">Address</p>
        <a href="https://www.google.com/maps/dir//Lawrence%20Piano%20Studio,%202512%20W%206th%20St.%20Suite%20B,%20Lawrence,%20KS%2066049" target="_blank" rel="noopener noreferrer" class="text-slate-600 dark:text-white/70 leading-relaxed hover:text-primary-dark dark:hover:text-white transition-colors block">
          2512 W 6th St. Suite B<br />
          Lawrence, KS 66049
        </a>
      </div>
    </div>

    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 mt-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary dark:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <p class="font-semibold text-slate-800 dark:text-white/90 mb-1">Email</p>
        <a href="mailto:contact@lawrencepiano.com" class="text-primary dark:text-primary hover:text-primary-dark dark:hover:text-white transition-colors">
          contact@lawrencepiano.com
        </a>
      </div>
    </div>
  </div>
</div>

      <!-- RIGHT: Web3Forms Contact Form -->
      <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-lg border border-[#1a2e5a]/20 p-8 lg:p-10">
        <h2 class="text-2xl font-bold font-heading text-[#1a2e5a] dark:text-white mb-2">
          Send Us a Message
        </h2>
        <p class="text-muted mb-8 text-sm">
          We do not store or sell any of this information; we only use it to reply back to your message.
        </p>

        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6" id="contact-form">
          <!-- Web3Forms Access Key -->
          <input type="hidden" name="access_key" value="215f1bc5-f66f-4762-be6c-e7c07274dde5" />
          <!-- Honeypot spam prevention -->
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
          <!-- Redirect after submit (optional) -->
          <!-- <input type="hidden" name="redirect" value="https://yourdomain.com/thank-you" /> -->

          <!-- Name Field -->
          <div>
            <label for="name" class="block text-sm font-semibold text-[#1a2e5a] dark:text-slate-200 mb-2">
              Full Name <span class="text-primary dark:text-primary">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full px-4 py-3 rounded-lg border-2 border-primary/20 dark:border-white/10 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200"
            />
          </div>

          <!-- Email Field -->
          <div>
            <label for="email" class="block text-sm font-semibold text-[#1a2e5a] dark:text-slate-200 mb-2">
              Email Address <span class="text-primary dark:text-primary">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@example.com"
              class="w-full px-4 py-3 rounded-lg border-2 border-primary/20 dark:border-white/10 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200"
            />
          </div>

          <!-- Subject Field -->
          <div>
            <label for="subject" class="block text-sm font-semibold text-[#1a2e5a] dark:text-slate-200 mb-2">
              Subject
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="Lesson inquiry, scheduling, etc."
              class="w-full px-4 py-3 rounded-lg border-2 border-primary/20 dark:border-white/10 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200"
            />
          </div>

          <!-- Message Field -->
          <div>
            <label for="message" class="block text-sm font-semibold text-[#1a2e5a] dark:text-slate-200 mb-2">
              Message <span class="text-primary dark:text-primary">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="Tell us about yourself, your experience level, and what you're hoping to achieve..."
              class="w-full px-4 py-3 rounded-lg border-2 border-primary/20 dark:border-white/10 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200 resize-y min-h-[120px]"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="btn-primary w-full shadow-md"
          >
            Send Message
          </button>

          <!-- Success/Error message placeholder -->
          <div id="result" class="hidden text-center py-3 px-4 rounded-lg font-medium text-sm"></div>
        </form>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const resultDiv = document.getElementById('result');

    if (form && resultDiv) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';
        }

        resultDiv.classList.add('hidden');
        resultDiv.textContent = '';

        const formData = new FormData(form);
        const object = Object.fromEntries(formData.entries());
        const json = JSON.stringify(object);

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
            },
            body: json,
          });

          const data = await response.json();

          if (response.ok && data.success) {
            resultDiv.textContent = 'Thank you! Your message has been sent. We\'ll be in touch soon.';
            resultDiv.className = 'text-center py-3 px-4 rounded-lg font-medium text-sm bg-green-50 text-green-800 border border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-700';
            form.reset();
          } else {
            throw new Error(data.message || 'Submission failed');
          }
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
          resultDiv.textContent = message;
          resultDiv.className = 'text-center py-3 px-4 rounded-lg font-medium text-sm bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/30 dark:text-red-300 dark:border-red-700';
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send Message';
          }
          resultDiv.classList.remove('hidden');
        }
      });
    }
  </script>
</Layout>
