---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import { headerData } from '~/navigation';
import Pricing from '~/components/widgets/Pricing.astro';
import { Image } from 'astro:assets';

import ericGroupLesson from '~/assets/images/studio_photos/eric_group_lesson.jpg';
import jenGroupLesson from '~/assets/images/studio_photos/jen_group_lesson.jpg';
import privateLesson from '~/assets/images/studio_photos/private_lesson.jpg';
import studentsRhythmGame from '~/assets/images/studio_photos/students_rhythm_game.jpg';
import childKeyboard from '~/assets/images/studio_photos/child_keyboard.jpg';

const metadata = {
  title: 'Lessons | Lawrence Piano Studio',
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header {...headerData} isDark={true} isTransparent={true} showToggleTheme={true} position="center" />
  </Fragment>

  <!-- ======== HERO BANNER ======== -->
  <section class="relative md:-mt-[76px] not-prose overflow-hidden">
    <div class="relative h-[420px] md:h-[520px] w-full">
      <Image
        src={ericGroupLesson}
        alt="Eric leading a group piano lesson at Lawrence Piano Studio"
        class="absolute inset-0 w-full h-full object-cover"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        loading="eager"
      />
      <!-- Dark overlay for text legibility -->
      <div class="absolute inset-0 bg-black/60 pt-20"></div>
      <!-- Centered text -->
      <div class="relative flex flex-col items-center justify-center h-full text-center px-4 pt-[76px]">
        <h1 class="text-4xl md:text-6xl font-bold font-heading text-white leading-tight mb-4">
          Our Lessons
        </h1>
        <p class="text-lg md:text-xl text-white max-w-2xl">
          From young beginners to adults — find the perfect piano lesson for your journey.
        </p>
      </div>
    </div>
  </section>

  <!-- ======== INTRO ======== -->
  <section class="py-12 px-4 sm:px-6 max-w-4xl mx-auto text-center">
    <p class="text-lg text-muted dark:text-slate-300 leading-relaxed">
      We offer three lesson formats designed to meet students where they are. Whether you or your child are just starting out,
      ready to develop alongside peers, or you prefer personalized one-on-one instruction, we have a program for you.
    </p>
  </section>

  <!-- ======== ACCORDION: LESSON TYPES ======== -->
  <section class="px-4 sm:px-6 pb-16 max-w-4xl mx-auto" id="lesson-types">

    <div class="space-y-4" id="lessons-accordion">

      <!-- ── Panel 1: Young Beginner Group ── -->
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm overflow-hidden">
        <button
          class="accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left group"
          aria-expanded="false"
          data-target="panel-young"
        >
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary dark:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div>
              <span class="text-xl font-bold text-[#1a2e5a] dark:text-white">Young Beginner Group</span>
              <span class="ml-3 text-sm font-medium text-primary dark:text-primary bg-primary/10 dark:bg-primary/10 px-2 py-0.5 rounded-full">Kindergarten – 1st Grade · 30 min/week</span>
            </div>
          </div>
          <svg
            class="accordion-icon flex-shrink-0 w-5 h-5 text-gray-500 transition-transform duration-300 rotate-180"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div id="panel-young" class="accordion-panel px-6 pb-8 hidden">
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <p class="text-muted dark:text-slate-300 leading-relaxed mb-6">
                Young beginner group lessons foster a young student's love of music by building a solid musical
                foundation in pianistic technique, rhythm recognition, beginning note reading, and song playing —
                all at a relaxed, age-appropriate pace. These group lessons are geared toward children between
                Kindergarten and 1st grade.
              </p>
              <h4 class="text-base font-bold text-[#1a2e5a] dark:text-white mb-3 uppercase tracking-wide">Activities (30 min)</h4>
              <ul class="space-y-2 text-muted dark:text-slate-300">
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-primary mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Work on solo piano pieces
                </li>
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-primary mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Practice finger exercises and note reading
                </li>
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-primary mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Clap and count rhythms
                </li>
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-primary mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Play musical games
                </li>
              </ul>
              <p class="mt-4 text-sm text-muted dark:text-slate-400">
                <strong>Class size:</strong> 6–8 students
              </p>
            </div>
            <div class="rounded-xl overflow-hidden shadow-md">
              <Image
                src={childKeyboard}
                alt="Young child learning piano at keyboard"
                class="w-full h-56 object-cover"
                widths={[400, 700]}
                sizes="(max-width: 768px) 100vw, 350px"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- ── Panel 2: Advancing Group ── -->
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm overflow-hidden">
        <button
          class="accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left group"
          aria-expanded="false"
          data-target="panel-advancing"
        >
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <span class="text-xl font-bold text-[#1a2e5a] dark:text-white">Advancing Group</span>
              <span class="ml-3 text-sm font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 px-2 py-0.5 rounded-full">1st – 6th Grade · 1 hour/week</span>
            </div>
          </div>
          <svg
            class="accordion-icon flex-shrink-0 w-5 h-5 text-gray-500 transition-transform duration-300"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div id="panel-advancing" class="accordion-panel px-6 pb-8 hidden">
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <p class="text-muted dark:text-slate-300 leading-relaxed mb-6">
                Group lessons allow students to share and learn from each other in a fun, structured environment,
                developing confidence through peer support. These group lessons are geared toward 1st through 6th graders.
              </p>
              <h4 class="text-base font-bold text-[#1a2e5a] dark:text-white mb-3 uppercase tracking-wide">Activities (60 min)</h4>

              <div class="space-y-4 text-muted dark:text-slate-300">
                <div>
                  <p class="font-semibold text-[#1a2e5a] dark:text-white mb-1">First 20 Minutes</p>
                  <ul class="space-y-1.5 ml-2">
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Work individually with a teacher on solo piece using an acoustic piano
                    </li>
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Fill out theory worksheets naming notes or counting rhythms
                    </li>
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Warm up on one of nine keyboards in the main room
                    </li>
                  </ul>
                </div>
                <div>
                  <p class="font-semibold text-[#1a2e5a] dark:text-white mb-1">Next 20 Minutes</p>
                  <ul class="space-y-1.5 ml-2">
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Practice the finger exercise of the week
                    </li>
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Play the two unison pieces of the week
                    </li>
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      <span><strong>(Fall)</strong> Develop improvisational skills using the Blues Scale (part of the December studio recital)</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      <span><strong>(Spring)</strong> Create and notate an original composition (part of the March studio recital)</span>
                    </li>
                  </ul>
                </div>
                <div>
                  <p class="font-semibold text-[#1a2e5a] dark:text-white mb-1">Last 20 Minutes</p>
                  <ul class="space-y-1.5 ml-2">
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Rehearse a 4-part piece with the group as an ensemble
                    </li>
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Play games like "Musical Basketball," "Musical Tic-Tac-Toe," and "Speed Note"
                    </li>
                    <li class="flex items-start gap-2">
                      <svg class="flex-shrink-0 w-4 h-4 text-indigo-500 mt-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      Record practice time from the previous week
                    </li>
                  </ul>
                </div>
              </div>
              <p class="mt-4 text-sm text-muted dark:text-slate-400">
                <strong>Class size:</strong> 6–8 students
              </p>
            </div>
            <div class="rounded-xl overflow-hidden shadow-md">
              <Image
                src={studentsRhythmGame}
                alt="Students playing a rhythm game during group piano lesson"
                class="w-full h-64 object-cover"
                widths={[400, 700]}
                sizes="(max-width: 768px) 100vw, 350px"
              />
              <div class="mt-3 rounded-xl overflow-hidden shadow-md">
                <Image
                  src={jenGroupLesson}
                  alt="Jen leading a group piano lesson"
                  class="w-full h-48 object-cover"
                  widths={[400, 700]}
                  sizes="(max-width: 768px) 100vw, 350px"
                />
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Panel 3: Private Lessons ── -->
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow-sm overflow-hidden">
        <button
          class="accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left group"
          aria-expanded="false"
          data-target="panel-private"
        >
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div>
              <span class="text-xl font-bold text-[#1a2e5a] dark:text-white">Private Lessons</span>
              <span class="ml-3 text-sm font-medium text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30 px-2 py-0.5 rounded-full">All Ages · 1-on-1 Instruction</span>
            </div>
          </div>
          <svg
            class="accordion-icon flex-shrink-0 w-5 h-5 text-gray-500 transition-transform duration-300"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div id="panel-private" class="accordion-panel px-6 pb-8 hidden">
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <p class="text-muted dark:text-slate-300 leading-relaxed mb-6">
                Private lessons allow teachers to work one-on-one with students to develop excellent piano
                technique and learn to play piano in many styles, ranging from Classical to Jazz and Pop.
                Private lessons are available for any age group, including adults.
              </p>
              <h4 class="text-base font-bold text-[#1a2e5a] dark:text-white mb-3 uppercase tracking-wide">Activities (30 min)</h4>
              <ul class="space-y-2 text-muted dark:text-slate-300">
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-emerald-500 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Practice technical exercises
                </li>
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-emerald-500 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Play a wide variety of pieces — Classical, Popular, and Jazz
                </li>
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-emerald-500 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Clap and count rhythms
                </li>
                <li class="flex items-start gap-2">
                  <svg class="flex-shrink-0 w-5 h-5 text-emerald-500 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  Note-finding and music theory related to the pieces
                </li>
              </ul>
              <p class="mt-4 text-sm text-muted dark:text-slate-400">
                <strong>Instruction:</strong> 1-on-1 with your teacher &nbsp;·&nbsp; <strong>Ages:</strong> All ages welcome
              </p>
            </div>
            <div class="rounded-xl overflow-hidden shadow-md">
              <Image
                src={privateLesson}
                alt="One-on-one private piano lesson"
                class="w-full h-56 object-cover"
                widths={[400, 700]}
                sizes="(max-width: 768px) 100vw, 350px"
              />
            </div>
          </div>
        </div>
      </div>

    </div><!-- /accordion -->
  </section>

  <!-- ======== PRICING WIDGET ======== -->
  <Pricing
    title="<span class='font-heading text-secondary dark:text-primary'>Tuition Comparison</span>"
    subtitle="Please visit our <a href='/info/policies' class='text-secondary dark:text-primary hover:underline font-medium'>policies page</a> for full details on our pricing structure, enrollment process, and studio policies."
    prices={[
      {
        title: 'Beginner Group',
        subtitle: 'Kindergarten – 1st Grade',
        price: 45,
        period: 'per month',
        items: [
          { description: '30 minutes per week' },
          { description: 'Kindergarten & 1st Grade' },
          { description: '6–8 students per class' },
          { description: 'Group lesson format' },
        ],
        callToAction: { text: 'Learn More', href: '/contact' },
      },
      {
        title: 'Advancing Group',
        subtitle: '1st – 6th Grade',
        price: 84,
        period: 'per month',
        hasRibbon: true,
        ribbonTitle: 'Popular',
        items: [
          { description: '1 hour per week' },
          { description: '1st through 6th Grade' },
          { description: '6–8 students per class' },
          { description: 'Group lesson format' },
        ],
        callToAction: { text: 'Learn More', href: '/contact', variant: 'primary' },
      },
      {
        title: 'Private Lessons',
        subtitle: 'All Ages',
        price: '116–120',
        period: 'per month',
        items: [
          { description: '30 minutes per lesson' },
          { description: 'All ages welcome' },
          { description: '1-on-1 instruction' },
          { description: 'Classical, Pop, Jazz & more' },
        ],
        callToAction: { text: 'Learn More', href: '/contact' },
      },
    ]}
  />

  <!-- ======== ACCORDION SCRIPT ======== -->
  <script>
    function initAccordion() {
      const triggers = document.querySelectorAll<HTMLButtonElement>('.accordion-trigger');

      triggers.forEach((trigger) => {
        // Remove any previously attached listeners by cloning
        const clone = trigger.cloneNode(true) as HTMLButtonElement;
        trigger.parentNode?.replaceChild(clone, trigger);
      });

      // Re-query after clone replacement
      document.querySelectorAll<HTMLButtonElement>('.accordion-trigger').forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const targetId = trigger.getAttribute('data-target');
          if (!targetId) return;

          const panel = document.getElementById(targetId);
          if (!panel) return;

          const icon = trigger.querySelector<SVGElement>('.accordion-icon');
          const isOpen = trigger.getAttribute('aria-expanded') === 'true';

          if (isOpen) {
            // Close this panel
            panel.classList.add('hidden');
            trigger.setAttribute('aria-expanded', 'false');
            icon?.classList.remove('rotate-180');
          } else {
            // Open this panel
            panel.classList.remove('hidden');
            trigger.setAttribute('aria-expanded', 'true');
            icon?.classList.add('rotate-180');
          }
        });
      });
    }

    // Run on initial load
    document.addEventListener('DOMContentLoaded', initAccordion);
    // Re-run on Astro view transitions
    document.addEventListener('astro:page-load', initAccordion);
  </script>
</Layout>
