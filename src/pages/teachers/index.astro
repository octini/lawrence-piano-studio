---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';

import ericImg from '~/assets/images/studio_photos/eric_sakumura.png';
import lauraImg from '~/assets/images/studio_photos/laura_king.png';
import jenImg from '~/assets/images/studio_photos/jen_hosler_updated.jpg';
import ginaImg from '~/assets/images/studio_photos/gina_lorenz.jpg';
import johnImg from '~/assets/images/studio_photos/john_eldridge.jpg';

const metadata = {
  title: 'Our Teachers | Lawrence Piano Studio',
};

const founders = [
  { name: 'Eric Sakumura', role: 'Founder & Co-Owner', img: ericImg, href: '/teachers/eric' },
  { name: 'Laura King', role: 'Co-Owner', img: lauraImg, href: '/teachers/laura' },
];

const teachers = [
  { name: 'Jen Hosler', role: 'Teacher', img: jenImg, href: '/teachers/jen' },
  { name: 'Gina Lorenz', role: 'Teacher', img: ginaImg, href: '/teachers/gina' },
  { name: 'John Eldridge', role: 'Teacher', img: johnImg, href: '/teachers/john' },
];
---

<Layout metadata={metadata}>
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <h1 class="text-4xl font-bold font-heading text-center mb-4 dark:text-white">Our Teachers</h1>
    <p class="text-center text-gray-600 dark:text-gray-400 mb-12 text-lg">
      At Lawrence Piano Studio, both our private instructors and our group lesson assistants are university-trained musicians. Our teachers' strong credentials mean we can offer knowledgable instruction to students at all levels, from beginners to advanced pianists.
    </p>

    <!-- Top row: Eric & Laura (2 columns on md+) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8 max-w-3xl mx-auto">
      {founders.map((teacher) => (
        <a href={teacher.href} class="group block rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 bg-white dark:bg-slate-800">
          <div class="overflow-hidden">
            <Image
              src={teacher.img}
              alt={teacher.name}
              width={400}
              height={400}
              format="webp"
              class="w-full object-cover aspect-square group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-5 text-center">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{teacher.name}</h2>
            <p class="text-sm text-primary-600 dark:text-primary-400 mt-1 font-medium">{teacher.role}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- Second row: Jen, Gina, John (3 columns on md+) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {teachers.map((teacher) => (
        <a href={teacher.href} class="group block rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 bg-white dark:bg-slate-800">
          <div class="overflow-hidden">
            <Image
              src={teacher.img}
              alt={teacher.name}
              width={400}
              height={400}
              format="webp"
              class="w-full object-cover aspect-square group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-5 text-center">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{teacher.name}</h2>
            <p class="text-sm text-primary-600 dark:text-primary-400 mt-1 font-medium">{teacher.role}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
