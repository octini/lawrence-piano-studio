---
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';

// Lawrence Piano Studio — Theme
// Light:  White bg | Navy text | Cobalt primary | Coral secondary | Gold accents
// Dark:   Deep Navy bg | White text | Gold primary | Coral/Cobalt accents
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Playfair Display Variable';
    --aw-font-heading: 'Playfair Display Variable';

    /* Light mode */
    --aw-color-primary: #1a56c4;       /* Cobalt */
    --aw-color-secondary: #e8614d;     /* Coral */
    --aw-color-accent: #c9a84c;        /* Gold */

    --aw-color-text-heading: #0f1f3d;  /* Navy */
    --aw-color-text-default: #1b2a4a;  /* Navy (slightly lighter) */
    --aw-color-text-muted: rgb(27 42 74 / 60%);
    --aw-color-bg-page: #ffffff;       /* White */

    --aw-color-bg-page-dark: #0b1222;  /* Deep Navy */

    ::selection {
      background-color: #c9a84c33;     /* Gold tint */
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Playfair Display Variable';
    --aw-font-heading: 'Playfair Display Variable';

    /* Dark mode */
    --aw-color-primary: #c9a84c;       /* Gold */
    --aw-color-secondary: #e8614d;     /* Coral */
    --aw-color-accent: #1a56c4;        /* Cobalt */

    --aw-color-text-heading: #f0f4fa;  /* Near-white */
    --aw-color-text-default: #dce6f5;  /* Soft white */
    --aw-color-text-muted: rgb(220 230 245 / 60%);
    --aw-color-bg-page: #0b1222;       /* Deep Navy */

    ::selection {
      background-color: #c9a84c44;     /* Gold tint */
      color: #f0f4fa;
    }
  }
</style>
